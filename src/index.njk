---
data: content/home.yml
---

<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <title>{{ data.title or '' }}</title>
    <style>
      body {
        margin: 0;
        font-family: Arial;
      }
      .hero {
        height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
        position: relative;
      }
      .media {
        position: absolute;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: -1;
      }
    </style>
  </head>
  <body>
    <div class="hero">
      {% set media = data.media or '' %}
      {% if media and '.mp4' in media %}
        <video class="media" autoplay muted loop playsinline>
          <source src="{{ media }}">
        </video>
      {% elif media %}
        <img class="media" src="{{ media }}" alt="">
      {% endif %}
      <h1>{{ data.title or '' }}</h1>
      <p>{{ data.subtitle or '' }}</p>
      {% if data.link %}
        <a href="{{ data.link }}">Acessar</a>
      {% endif %}
    </div>
  </body>
</html>