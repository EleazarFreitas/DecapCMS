---
permalink: /
---

<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <title>{{ home.title or '' }}</title>
    <!-- Script do Netlify Identity -->
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <style>
      body {
        margin: 0;
        font-family: Arial;
      }
      .hero {
        height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
        position: relative;
      }
      .media {
        position: absolute;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: -1;
      }
    </style>
  </head>
  <body>
    <div class="hero">
      {% set media = home.media or '' %}
      {% if media and '.mp4' in media %}
        <video class="media" autoplay muted loop playsinline>
          <source src="{{ media }}">
        </video>
      {% elif media %}
        <img class="media" src="{{ media }}" alt="">
      {% endif %}
      <h1>{{ home.title or '' }}</h1>
      <p>{{ home.subtitle or '' }}</p>
      {% if home.link %}
        <a href="{{ home.link }}">Acessar</a>
      {% endif %}
    </div>
    <script>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", user => {
          if (!user) {
            window.netlifyIdentity.on("login", () => {
              document.location.href = "/admin/";
            });
          }
        });
      }
    </script>
  </body>
</html>